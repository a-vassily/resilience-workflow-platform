    ).mappings().first()\n        return dict(row) if row else None\n\n\ndef update_incident_status(incident_id: str, status: str, decision_payload: dict[str, Any] | None = None) -> None:\n    decision_payload = decision_payload or {}\n    with get_session() as session:\n        session.execute(\n            text(\n                \"\"\"\n                UPDATE candidate_incidents\n                SET status = :status,\n                    decision = decision || CAST(:decision_payload AS jsonb),\n                    updated_at = now()\n                WHERE incident_id = :incident_id\n                \"\"\"\n            ),\n            {\n                'incident_id': incident_id,\n                'status': status,\n                'decision_payload': json.dumps(decision_payload),\n            },\n        )\n\n\ndef insert_review_action(incident_id: str, action_type: str, actor: str, notes: str | None, payload: dict[str, Any]) -> None:\n    with get_session() as session:\n        session.execute(\n            text(\n                \"\"\"\n                INSERT INTO review_actions (incident_id, action_type, actor, notes, payload)\n                VALUES (:incident_id, :action_type, :actor, :notes, CAST(:payload AS jsonb))\n                \"\"\"\n            ),\n            {\n                'incident_id': incident_id,\n                'action_type': action_type,\n                'actor': actor,\n                'notes': notes,\n                'payload': json.dumps(payload),\n            },\n        )\n\n\ndef list_review_actions(incident_id: str) -> list[dict[str, Any]]:\n    with get_session() as session:\n        rows = session.execute(\n            text('SELECT * FROM review_actions WHERE incident_id = :incident_id ORDER BY created_at DESC'),\n            {'incident_id': incident_id},\n        ).mappings().all()\n        return [dict(r) for r in rows]\n\n\ndef insert_ai_request(incident_id: str, workload_type: str, model_id: str, prompt_template_version: str